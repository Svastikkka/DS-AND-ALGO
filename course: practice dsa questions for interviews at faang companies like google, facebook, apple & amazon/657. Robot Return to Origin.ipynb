    "position = [0,0]\n",
    "moves = \"LL\"\n",
    "for i in moves:\n",
    "    if i is \"L\":\n",
    "        position = position[0]-1\n",
    "    if i is \"R\":\n",
    "        position = position[0]+1\n",
    "    if i is \"U\":\n",
    "        position = position[1]+1\n",
    "    if i is \"D\":\n",
    "        position = position[1]-1"
   ]
